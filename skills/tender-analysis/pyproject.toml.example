# pyproject.toml 示例文件
# 复制此文件到项目根目录，重命名为 pyproject.toml
# 然后使用 `uv sync` 安装依赖

[project]
name = "tender-analysis-project"
version = "0.1.0"
description = "投标文件分析项目"
requires-python = ">=3.10"
dependencies = [
    "python-docx>=1.0.0",
    "pdfplumber>=0.10.0",
    "docx2txt>=0.8",
    "openpyxl>=3.1.0",
    "xlrd>=2.0.0",
]

[project.optional-dependencies]
ocr = [
    "pytesseract>=0.3.10",
    "pdf2image>=1.16.0",
]
pdf-tables = [
    "tabula-py>=2.5.0",
]

[tool.uv]
dev-dependencies = []

# 使用说明：
# 1. 复制此文件到项目根目录，重命名为 pyproject.toml
# 2. 运行 `uv sync` 自动创建虚拟环境并安装依赖
# 3. 运行 `uv sync --extra ocr` 安装 OCR 相关依赖（如需要）
# 4. 运行 `uv sync --extra pdf-tables` 安装 PDF 表格提取依赖（如需要）
